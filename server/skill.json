        "static_path": "data/menus/",
        "api_endpoint": null,
        "freshness": "daily"
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "get_service_info",
