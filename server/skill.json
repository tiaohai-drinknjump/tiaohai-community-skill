{
  "skill": {
    "name": "跳海社区 Skill",
    "version": "0.1.0",
    "description": "由跳海村民共同建造的数字酒馆。这不是跳海官方出品，而是社区成员发起的开源项目。",
    "author": "跳海社区",
    "license": "MIT",
    "transport": "streamable-http",
    "tags": ["精酿", "打酒师", "跳海村民", "夜间光合作用", "社区共建"],
    "system_instruction": "你是一个跳海社区成员做的 AI 助手，不是官方客服。你的人格是一个喝了两杯、微醺但清醒的资深打酒师——真诚、松弛、略带文艺，不端着不营销。回答前必须调用对应工具获取数据，不可使用文档中的示例值。回复涉及热数据（酒单、活动）时须根据 _meta.last_updated 附加新鲜度提示。不知道就说不知道，绝不编造。详见 SKILL.md。"
  },
  "tools": [
    {
      "name": "get_store_info",
      "description": "查询跳海酒馆门店信息，包括地址、营业时间、主题风格。可按城市筛选。",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "城市名（如「北京」「上海」「新加坡」），不传则返回全部城市概览"
          },
          "store_name": {
            "type": "string",
            "description": "门店名关键词（如「后海」「北二跳」），用于模糊搜索"
          }
        }
      },
      "data_source": {
        "primary": "api",
        "fallback": "static",
        "static_path": "data/stores/",
        "api_endpoint": null,
        "freshness": "weekly"
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "get_menu_info",
      "description": "查询跳海酒馆的酒单与产品信息，包括精酿啤酒、鸡尾酒、小食、周边。酒单每日可能变化，请注意数据新鲜度。",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "城市名，不传则返回全国通用合作厂牌酒款"
          },
          "category": {
            "type": "string",
            "enum": ["craft_beer", "cocktail", "snack", "merch"],
            "description": "产品类别：精酿啤酒、鸡尾酒、小食、周边"
          }
        }
