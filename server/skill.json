    {
      "name": "post_bottle",
      "description": "投递一个漂流瓶留言。每天北京时间20:00统一揭晓。留言不可包含电话/微信号等联系方式，线下见面靠描述（穿什么、坐哪）。每人每天最多3个。",
      "parameters": {
        "type": "object",
        "required": ["city", "message", "identity"],
        "properties": {
          "city": {
            "type": "string",
            "description": "城市名"
          },
          "store": {
            "type": "string",
            "description": "门店名（可选，不填则该城市所有店可见）"
          },
          "message": {
            "type": "string",
            "description": "留言内容（不可包含电话/微信号）"
          },
          "identity": {
            "type": "string",
            "enum": ["anonymous", "nickname"],
            "description": "匿名或留昵称"
          },
          "nickname": {
            "type": "string",
            "description": "昵称（identity=nickname 时填写）"
          },
          "meet_time": {
            "type": "string",
            "description": "想见面的时间（如「今晚十点」「九点半」）"
          }
        }
      },
